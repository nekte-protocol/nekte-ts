{
  "name": "@nekte/client",
  "version": "0.2.0",
  "description": "NEKTE client — lazy discovery, zero-schema invocation, budget-aware",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nekte/core": "^0.2.0"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0"
  },
  "peerDependenciesMeta": {
    "@grpc/grpc-js": { "optional": true },
    "@grpc/proto-loader": { "optional": true }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/*.map"
  ],
  "license": "MIT"
}
